      "name": "Generate Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Captura la respuesta en formato JSON\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "// Guarda el access_token en una variable global\r",
              "pm.globals.set(\"access_token\", jsonData.access_token);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
