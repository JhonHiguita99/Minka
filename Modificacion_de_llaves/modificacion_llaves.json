							"    method: 'POST',\r",
							"    header: {\r",
							"        'Content-Type': 'application/x-www-form-urlencoded'\r",
							"    },\r",
							"    body: {\r",
							"        mode: 'urlencoded',\r",
							"        urlencoded: [\r",
							"            { key: 'grant_type', value: 'client_credentials' },\r",
							"            { key: 'client_id', value: pm.environment.get(\"client_id\") },\r",
							"            { key: 'client_secret', value: pm.environment.get(\"client_secret\") },\r",
							"            { key: 'audience', value: pm.environment.get(\"audience\") } // opcional según el proveedor\r",
							"        ]\r",
							"    }\r",
							"}, function (err, res) {\r",
							"    if (err) {\r",
							"        console.log(\"Error al obtener el token:\", err);\r",
							"    } else {\r",
							"        let token = res.json().access_token;\r",
							"        pm.environment.set(\"access_token\", token);\r",
							"    }\r",
							"});\r",
							"\r",
							"\r",
							"\r",
							"// Función para generar una cadena aleatoria de dígitos de longitud especificada para el campo NUMERO DE CUENTA\r",
							"function generateRandomNumericString(length) {\r",
							"    const charset = '0123456789';  // Conjunto de caracteres numéricos\r",
							"    let randomString = '';\r",
							"    for (let i = 0; i < length; i++) {\r",
							"        const randomIndex = Math.floor(Math.random() * charset.length);\r",
							"        randomString += charset[randomIndex];\r",
							"    }\r",
							"    return randomString;\r",
							"}\r",
							"\r",
							"// Genera un valor aleatorio de 34 dígitos\r",
							"const randomNumericValue = generateRandomNumericString(34);\r",
							"\r",
							"// Establece el valor aleatorio en una variable\r",
							"pm.variables.set(\"randomNumericValue\", randomNumericValue)"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
