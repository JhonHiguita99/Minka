	"item": [
		{
			"name": "DC6_CP1 Validar la funcionalidad Modificación Nombre",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"pm.sendRequest({\r",
							"    url: 'https://ach-minka-stg.transferenciasinmediatas.com/oauth/token',\r",
							"    method: 'POST',\r",
							"    header: {\r",
							"        'Content-Type': 'application/x-www-form-urlencoded'\r",
							"    },\r",
							"    body: {\r",
							"        mode: 'urlencoded',\r",
							"        urlencoded: [\r",
							"            { key: 'grant_type', value: 'client_credentials' },\r",
							"            { key: 'client_id', value: pm.environment.get(\"client_id\") },\r",
							"            { key: 'client_secret', value: pm.environment.get(\"client_secret\") },\r",
							"            { key: 'audience', value: pm.environment.get(\"audience\") } // opcional según el proveedor\r",
							"        ]\r",
							"    }\r",
							"}, function (err, res) {\r",
							"    if (err) {\r",
							"        console.log(\"Error al obtener el token:\", err);\r",
							"    } else {\r",
							"        let token = res.json().access_token;\r",
							"        pm.environment.set(\"access_token\", token);\r",
							"    }\r",
							"});\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"let response = pm.response.json();\r",
							"\r",
							"// Verificar que NOMBRE se haya modificado\r",
							"pm.test(\"El campo firstName es 'SERGIO'\", function () {\r",
							"    pm.expect(response.labels.firstName).to.eql(\"SERGIO\");\r",
							" \r",
							"});\r",
							"\r",
							"pm.test(\"El campo secondName es 'ANDRES'\", function () {\r",
							"    pm.expect(response.labels.secondName).to.eql(\"ANDRES\");\r",
							" \r",
							"});\r",
							"\r",
							"\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"auth": {
					"type": "bearer",
