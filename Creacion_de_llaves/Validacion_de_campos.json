			"name": "Validacion de campos",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const randomCel = _.random(3102047071,3992047071)\r",
							"pm.variables.set(\"randomCel\", randomCel );\r",
							"// Genera un valor aleatorio\r",
							"let randomValue = Math.random();\r",
							"\r",
							"// Generar número aleatorio de 12 dígitos\r",
							"let identificacion = Math.floor(Math.random() * 9e11 + 1e11).toString() + Math.floor(Math.random() * 1e3).toString().padStart(3, '0');\r",
							"\r",
							"// Guardar como variable de entorno\r",
							"pm.environment.set(\"identificacion\", identificacion);\r",
							"\r",
							"console.log(\"Identificación generada:\", identificacion);\r",
							"\r",
							"// Generar una parte aleatoria para el nombre del correo\r",
							"function generateRandomString(length) {\r",
							"    const characters = 'abcdefghijklmnopqrstuvwxyz0123456789';\r",
							"    let result = '';\r",
							"    for (let i = 0; i < length; i++) {\r",
							"        result += characters.charAt(Math.floor(Math.random() * characters.length));\r",
							"    }\r",
							"    return result;\r",
							"}\r",
							"\r",
							"// Configurar el dominio del correo\r",
							"const domain = 'example.com'; // Cambia este dominio si necesitas otro\r",
							"const randomLocalPart = generateRandomString(8); // Parte local del correo (antes del @)\r",
							"\r",
							"// Generar el correo completo\r",
							"const randomEmail = `${randomLocalPart}@${domain}`;\r",
							"\r",
							"// Guardar el correo en variables de entorno o colección\r",
							"pm.environment.set('randomEmail', randomEmail);\r",
							"\r",
							"\r",
							"\r",
							"\r",
							"// Generar una cadena aleatoria de 10 caracteres para el campo ALFANUMERICO\r",
							"function generateRandomString(length) {\r",
							"    const characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';\r",
							"    let result = '';\r",
							"    for (let i = 0; i < length; i++) {\r",
							"        result += characters.charAt(Math.floor(Math.random() * characters.length));\r",
							"    }\r",
							"    return result;\r",
							"}\r",
							"\r",
							"// Crear la variable\r",
							"const alfanumerico = `@${generateRandomString(10)}`;\r",
							"pm.environment.set('alfanumerico', alfanumerico);\r",
							"\r",
							"\r",
							"\r",
							"\r",
							"// Generar una cadena de 8 dígitos aleatorios para el campo MERCHANTID\r",
							"function generateRandomDigits(length) {\r",
							"    let result = '';\r",
							"    for (let i = 0; i < length; i++) {\r",
							"        result += Math.floor(Math.random() * 10); // Generar un dígito aleatorio entre 0 y 9\r",
							"    }\r",
							"    return result;\r",
							"}\r",
							"\r",
							"// Crear la variable con prefijo '00'\r",
							"const merchant = `00${generateRandomDigits(8)}`;\r",
							"pm.environment.set('merchant', merchant);\r",
							"\r",
							"\r",
							"\r",
							"// Función para generar una cadena aleatoria de dígitos de longitud especificada para el campo NUMERO DE CUENTA\r",
							"function generateRandomNumericString(length) {\r",
							"    const charset = '0123456789';  // Conjunto de caracteres numéricos\r",
							"    let randomString = '';\r",
							"    for (let i = 0; i < length; i++) {\r",
							"        const randomIndex = Math.floor(Math.random() * charset.length);\r",
							"        randomString += charset[randomIndex];\r",
							"    }\r",
							"    return randomString;\r",
							"}\r",
							"\r",
							"// Genera un valor aleatorio de 34 dígitos\r",
							"const randomNumericValue = generateRandomNumericString(34);\r",
							"\r",
							"// Establece el valor aleatorio en una variable\r",
							"pm.variables.set(\"randomNumericValue\", randomNumericValue);\r",
							"\r",
							"\r",
							"//OBTENER FECHA ACTUAL\r",
							"const date = new Date();\r",
							" \r",
							"// Obtener componentes con ceros a la izquierda\r",
							"function pad(num, size = 2) {\r",
							"    return ('00' + num).slice(-size);\r",
							"}\r",
							" \r",
							"// Obtener la zona horaria en formato -05:00\r",
							"function getTimeZoneOffset(date) {\r",
							"    const offset = -date.getTimezoneOffset(); // en minutos\r",
							"    const sign = offset >= 0 ? '+' : '-';\r",
							"    const hours = pad(Math.floor(Math.abs(offset) / 60));\r",
							"    const minutes = pad(Math.abs(offset) % 60);\r",
							"    return `${sign}${hours}:${minutes}`;\r",
							"}\r",
							" \r",
							"const isoDate = `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}:${pad(date.getSeconds())}.${pad(date.getMilliseconds(), 3)}${getTimeZoneOffset(date)}`;\r",
							" \r",
							"pm.environment.set(\"fecha_actual_formato_iso\", isoDate);\r",
							"\r",
							"\r",
							"\r",
							"pm.sendRequest({\r",
							"    url: 'https://ach-minka-stg.transferenciasinmediatas.com/oauth/token',\r",
							"    method: 'POST',\r",
							"    header: {\r",
							"        'Content-Type': 'application/x-www-form-urlencoded'\r",
							"    },\r",
							"    body: {\r",
							"        mode: 'urlencoded',\r",
							"        urlencoded: [\r",
							"            { key: 'grant_type', value: 'client_credentials' },\r",
							"            { key: 'client_id', value: pm.environment.get(\"client_id\") },\r",
							"            { key: 'client_secret', value: pm.environment.get(\"client_secret\") },\r",
							"            { key: 'audience', value: pm.environment.get(\"audience\") } // opcional según el proveedor\r",
							"        ]\r",
							"    }\r",
							"}, function (err, res) {\r",
							"    if (err) {\r",
							"        console.log(\"Error al obtener el token:\", err);\r",
							"    } else {\r",
							"        let token = res.json().access_token;\r",
							"        pm.environment.set(\"access_token\", token);\r",
							"    }\r",
							"});\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
