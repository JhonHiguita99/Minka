		{
			"name": "Signer CORREO ELECTRONICO regex",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"let jsonData = pm.response.json();\r",
							"\r",
							"// Este es el patrón que estás buscando exactamente:\r",
							"const expectedPattern = \"^[a-zA-Z-0-9]{1}[a-zA-Z-0-9.!#$&'*+/=?^_`{|}~-]{1,29}@[a-zA-Z0-9.-]{1,57}\\\\.[a-zA-Z]{2,3}$\";\r",
							"\r",
							"// Extraemos lo que está entre las primeras dos barras diagonales del mensaje\r",
							"pm.test(\"Validar que el patrón esté presente en el mensaje\", function () {\r",
							"    let message = jsonData?.error?.message || \"\";\r",
							"\r",
							"    // Esta expresión regular busca algo entre dos \"/.../\" (el patrón dentro del mensaje)\r",
							"    let match = message.match(/\\/(.+)\\/$/);\r",
							"\r",
							"    if (match && match[1]) {\r",
							"        let extractedPattern = match[1];\r",
							"        console.log(\"Extraído:\", extractedPattern);\r",
							"        pm.expect(extractedPattern).to.eql(expectedPattern);\r",
							"    } else {\r",
							"        console.log(\"No se encontró patrón en el mensaje.\");\r",
							"        pm.expect.fail(\"No se encontró patrón en el mensaje.\");\r",
							"    }\r",
							"});\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
